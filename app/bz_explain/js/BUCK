oncall("build_infra")

YARN_OFFLINE_MIRROR = "."

genrule(
    name = "html",
    srcs = [":files"],
    out = "explain.html",
    cmd = '$(exe :build_html_script) --yarn "$(exe third_party//yarn:yarn)" --yarn-offline-mirror "{yarn_offline_mirror}" -o "$OUT" --src "$(location :files)" --tmp "$TMP"'.format(yarn_offline_mirror = YARN_OFFLINE_MIRROR),
)

filegroup(
    name = "files",
    srcs = glob(
        [
            "src/**",
            "*",
        ],
        exclude = [
            "node_modules/**",
            "dist/**",
        ],
    ) + [":schema_ts"],
)

genrule(
    name = "schema_ts",
    srcs = [
        "explain.fbs",
    ],
    out = "src/fbs",
    cmd = "$(exe third_party//flatbuffers:flatc) --ts -o ${OUT} ${SRCS}",
    default_outs = ["."],
)

python_binary(
    name = "build_html_script",
    main_function = ".build_html.main",
    main_src = "build_html.py",
)

export_file(
    name = "explain.fbs",
)
