load("@fbcode//bz:buck_rust_binary.bzl", "buck_rust_binary")
# @oss-disable[end= ]: load("@fbcode_macros//build_defs:platform_utils.bzl", "platform_utils")
load("@fbsource//tools/build_defs:rust_library.bzl", "rust_library")
load(":transition.bzl", "bz_client_transition_alias")

oncall("build_infra")

prelude = native

rust_library(
    name = "bz",
    srcs = glob(["src/**/*.rs"]),
    rustc_flags = select({
        ":bz_client_only_build": ["--cfg=client_only"],
        "DEFAULT": [],
    }),
    deps = [
        "fbsource//third-party/rust:backtrace",
        "fbsource//third-party/rust:clap",
        "fbsource//third-party/rust:tokio",
        "fbsource//third-party/rust:tracing",
        "//bz/app/bz_client:buck2_client",
