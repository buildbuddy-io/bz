load(":transition.bzl", "bz_client_transition_alias")

oncall("build_infra")

prelude = native

rust_library(
    name = "bz",
    srcs = glob(["src/**/*.rs"]),
    rustc_flags = select({
        ":bz_client_only_build": ["--cfg=client_only"],
        "DEFAULT": [],
    }),
    deps = [
        "third_party//rust:backtrace",
