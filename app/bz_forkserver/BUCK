oncall("build_infra")

rust_library(
    name = "bz_forkserver",
    srcs = glob(
        ["src/**/*.rs"],
    ),
    compatible_with = [
        "ovr_config//os:linux",
        "ovr_config//os:macos",
    ],
    deps = [
        "fbsource//third-party/rust:arc-swap",
        "fbsource//third-party/rust:async-trait",
        "fbsource//third-party/rust:futures",
        "fbsource//third-party/rust:libc",
        "fbsource//third-party/rust:rand",
        "fbsource//third-party/rust:tokio",
        "fbsource//third-party/rust:tokio-stream",
        "fbsource//third-party/rust:tonic",
        "//bz/deps/allocative/allocative:allocative",
        "//bz/app/bz_common:bz_common",
        "//bz/app/bz_core:bz_core",
        "//bz/app/bz_data:bz_data",
        "//bz/app/bz_error:bz_error",
        "//bz/app/bz_execute_local:bz_execute_local",
        "//bz/app/bz_forkserver_proto:bz_forkserver_proto",
        "//bz/app/bz_fs:bz_fs",
        "//bz/app/bz_grpc:bz_grpc",
        "//bz/app/bz_resource_control:bz_resource_control",
        "//bz/app/bz_util:bz_util",
        "//bz/deps/gazebo/dupe:dupe",
    ] + select({
        "DEFAULT": [],
        "ovr_config//os:linux": [
            "fbsource//third-party/rust:nix",
            ":bz_miniperf_data",
        ],
    }),
)

rust_linkable_symbol(
    name = "bz_miniperf_data",
    content_bytes = "//bz/app/bz_miniperf:bz_miniperf",
)
