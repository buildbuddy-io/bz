oncall("build_infra")

# Constraint controlling the "pagable" Cargo feature of the starlark crate.
# When enabled, pagable serialization/deserialization support for starlark values is enabled.
# Buck2 internal targets set this to "enabled" via package modifier in buck2/PACKAGE.
# External consumers get "disabled" by default.
constraint(
    name = "pagable",
    default = "disabled",
    execution_modifier = True,
    values = [
        "enabled",
        "disabled",
    ],
    visibility = ["PUBLIC"],
)

alias(
    name = "starlark-bin",
    actual = "//deps/starlark-rust/starlark_bin:starlark_bin",
)

filegroup(
    name = "testcases",
    srcs = glob([
        "src/**/golden/**",
        "src/**/*.golden",
        "testcases/**",
    ]),
    copy = False,
)

rust_library(
    name = "starlark",
    srcs = glob(["src/**/*.rs"]),
    # `pagable` controls type registration for starlark values which shouldn't be enforced everywhere.
    # `pagable_dep` controls whether to depend on pagable at all, used for OSS because to support stable rustc.
    features = select({
        ":pagable[enabled]": [
            "pagable",
            "pagable_dep",
        ],
        "DEFAULT": ["pagable_dep"],
    }),
    rustc_flags = [
        "--cfg=rust_nightly",
    ] + select({
        ":pagable[enabled]": ["--cfg=starlark_require_heap_names"],
        "DEFAULT": [],
    }),
    test_deps = [
        "third_party//rust:rand",
        # This is a hack to build `:testcases` when invoking a test.
        # Otherwise `OUT_DIR` is set, but it points to non-existing directory.
        # This is likely a bug in `rust_test` rule.
        ":testcases",
    ],
    test_env = {
        # Some of our tests include testcase files relative to CARGO_MANIFEST_DIR.
        # This is a hack that allows both `cargo test` and `buck test` to work.
        "CARGO_MANIFEST_DIR": "$(location :testcases)",
    },
    deps = [
        "third_party//rust:anyhow",
        "third_party//rust:bumpalo",
        "third_party//rust:debugserver-types",
        "third_party//rust:derivative",
        "third_party//rust:derive_more",
        "third_party//rust:either",
        "third_party//rust:erased-serde",
        "third_party//rust:hashbrown",
        "third_party//rust:inventory",
        "third_party//rust:itertools",
        "third_party//rust:maplit",
        "third_party//rust:memoffset",
        "third_party//rust:num-bigint",
        "third_party//rust:num-traits",
        "third_party//rust:once_cell",
        "third_party//rust:paste",
        "third_party//rust:ref-cast",
        "third_party//rust:regex",
        "third_party//rust:rustyline",
        "third_party//rust:serde",
        "third_party//rust:serde_json",
        "third_party//rust:static_assertions",
        "third_party//rust:strsim",
        "third_party//rust:textwrap",
        "third_party//rust:thiserror",
        "//deps/allocative/allocative:allocative",
        "//deps/gazebo/cmp_any:cmp_any",
        "//deps/gazebo/display_container:display_container",
        "//deps/gazebo/dupe:dupe",
        "//deps/pagable:pagable",
        "//deps/starlark-rust/starlark_derive:starlark_derive",
        "//deps/starlark-rust/starlark_map:starlark_map",
        "//deps/starlark-rust/starlark_syntax:starlark_syntax",
    ],
)
