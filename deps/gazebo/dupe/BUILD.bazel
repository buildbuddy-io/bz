load("@crates//:defs.bzl", "aliases", "all_crate_deps")
load("@rules_rust//cargo:defs.bzl", "cargo_build_script")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_proc_macro")

package(default_visibility = ["//visibility:public"])

COMMON_RUSTC_ENV = {
    "CARGO_MANIFEST_DIR": "deps/gazebo/dupe",
    "CARGO_PKG_AUTHORS": "Facebook",
    "CARGO_PKG_DESCRIPTION": "Marker for types which are cheap to clone",
    "CARGO_PKG_HOMEPAGE": "",
    "CARGO_PKG_LICENSE": "MIT OR Apache-2.0",
    "CARGO_PKG_LICENSE_FILE": "",
    "CARGO_PKG_NAME": "dupe",
    "CARGO_PKG_README": "",
    "CARGO_PKG_REPOSITORY": "https://github.com/facebookincubator/gazebo",
    "CARGO_PKG_VERSION": "0.9.1",
    "CARGO_PKG_VERSION_MAJOR": "0",
    "CARGO_PKG_VERSION_MINOR": "9",
    "CARGO_PKG_VERSION_PATCH": "1",
    "CARGO_PKG_VERSION_PRE": "",
    }

rust_library(
    name = "dupe",
    crate_name = "dupe",
    crate_root = "src/lib.rs",
    srcs = glob(["src/**/*.rs"]),
    edition = "2024",
    aliases = aliases(),
    deps = all_crate_deps(normal = True) + [],
    proc_macro_deps = all_crate_deps(proc_macro = True) + [
        "//deps/gazebo/dupe_derive:dupe_derive",
    ],
    rustc_env = COMMON_RUSTC_ENV,
    compile_data = glob([
        "**/*",
    ], allow_empty = True, exclude = [
        "BUILD.bazel",
        "BUCK",
        "Cargo.toml",
        "fuzz/**",
    ]),
)
