[cells]
root = .
prelude = prelude
toolchains = toolchains
none = none

[cell_aliases]
config = prelude
buck = none

[external_cells]
  prelude = bundled


[parser]
target_platform_detector_spec = target:root//...->root//bz_utils/platforms:windows_debug

[build]
execution_platforms = root//bz_utils/platforms:default

[buck2_re_client]
action_cache_address = grpc://localhost:8980
engine_address = grpc://localhost:8980
cas_address = grpc://localhost:8980
tls = false
instance_name = fuse
