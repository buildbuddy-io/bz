[cells]
gh_facebook_buck2 = .
prelude = cells/prelude
bazel_tools = cells/bazel_tools

[cell_aliases]
root = gh_facebook_buck2
prelude = prelude
bazel_tools = bazel_tools

[oss]
internal_cell = fbcode
stripped_root_dirs = buck2

[project]
ignore = \
    app/bz_explain, \
    app_dep_graph_rules, \
    examples, \
    integrations/rust-project/tests, \
    tests

[rust]
default_edition = 2024
