[cells]
bz = .
prelude = cells/prelude
bazel_tools = cells/bazel_tools
third_party = third_party

[cell_aliases]
root = bz
bz = bz
prelude = prelude
bazel_tools = bazel_tools
third_party = third_party

[project]
ignore = \
    app/bz_explain, \
    app_dep_graph_rules, \
    examples, \
    integrations/rust-project/tests, \
    tests

[rust]
default_edition = 2024
