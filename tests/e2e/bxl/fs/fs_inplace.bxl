load("@prelude//:asserts.bzl", "asserts")

def _impl(ctx):
    # special case where workspace is a project and a cell
    asserts.true(ctx.fs.exists("root//workspace"))
    asserts.false(ctx.fs.exists("root//fake/path"))
    asserts.true(ctx.fs.is_dir("root//workspace"))
    asserts.false(ctx.fs.is_file("root//workspace"))

    # test workspace as well
    asserts.true(ctx.fs.exists("root//buck2"))
    asserts.false(ctx.fs.exists("root//buck100"))
    asserts.true(ctx.fs.is_dir("root//buck2"))
    asserts.false(ctx.fs.is_file("root//buck2"))

    outputs = []
    for result in ctx.fs.list("//tests/e2e/bxl/fs/some_folder"):
        outputs.append(result)
    asserts.equals(len(outputs), 2)

test = bxl_main(
    impl = _impl,
    cli_args = {},
)
