oncall("build_infra")

fb_native = native

fb_native.constraint_setting(
    name = "config",
)

fb_native.constraint_value(
    name = "on",
    constraint_setting = ":config",
)

fb_native.configuration_alias(
    name = "config_alias",
    actual = ":config",
)

fb_native.configuration_alias(
    name = "on_alias",
    actual = ":on",
)

fb_native.platform(
    name = "platform",
    constraint_values = [
        ":on_alias",
    ],
)
