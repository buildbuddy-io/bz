load("//tests:buck_e2e.bzl", "bz_core_tests")

oncall("build_infra")

bz_core_tests(
    target_extra_attrs = {
        "test_actions": {
            "deps": [
                "third_party//pypi/aiohttp:aiohttp",
            ],
            "env": {
                # `cpe::x2p` resolves `localhost` incorrectly, and test fails.
                "CPE_RUST_X2P_SUPPORTS_VPNLESS": "0",
            },
        },
        "test_run_action_timeout": {
            "compatible_with": [
                "ovr_config//os:linux",
                "ovr_config//os:macos",
            ],
        },
    },
)
