load(":defs.bzl", "normal_nested_invocation", "trace_nested_invocation")

trivial_build(name = "trivial")

normal_nested_invocation(
    name = "nested_normal",
    bz_path = read_root_config("nested", "bz_path"),
)

trace_nested_invocation(
    name = "nested_trace",
    bz_path = read_root_config("nested", "bz_path"),
)
