load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")
load("@io_bazel_rules_go//proto:compiler.bzl", "go_proto_compiler")
load("@io_bazel_rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load(":aspect_rule_attrs.bzl", "go_proto_like", "proto_like")
load(":aspect_toolchains.bzl", "consumer", "leaf", "missing_toolchain_consumer", "required_leaf")

package(default_visibility = ["//visibility:public"])

go_library(
    name = "hello_lib",
    srcs = ["lib.go"],
    importpath = "example.com/hello/lib",
)

go_library(
    name = "combined_core",
    srcs = ["combined_core.go"],
    importpath = "example.com/hello/combined",
)

go_library(
    name = "combined",
    srcs = ["combined_extra.go"],
    embed = [":combined_core"],
    importpath = "example.com/hello/combined",
)

go_binary(
    name = "hello",
    srcs = ["main.go"],
    deps = [":hello_lib"],
)

go_binary(
    name = "root_alias_hello",
    srcs = ["main.go"],
    deps = ["@hello_go_root//:hello_lib"],
)

proto_library(
    name = "message_proto",
    srcs = ["message.proto"],
)

go_proto_library(
    name = "message_go_proto",
    proto = ":message_proto",
)

go_proto_compiler(
    name = "message_compiler",
    plugin = ":hello",
)

toolchain_type(name = "consumer_toolchain_type")

toolchain_type(name = "aspect_toolchain_type")

toolchain_type(name = "missing_aspect_toolchain_type")

leaf(name = "aspect_leaf")

required_leaf(name = "missing_aspect_toolchain_leaf")

consumer(
    name = "aspect_toolchain_ctx",
    dep = ":aspect_leaf",
)

missing_toolchain_consumer(
    name = "missing_mandatory_aspect_toolchain_not_applicable",
    dep = ":aspect_leaf",
)

missing_toolchain_consumer(
    name = "missing_mandatory_aspect_toolchain_applicable",
    dep = ":missing_aspect_toolchain_leaf",
)

proto_like(
    name = "aspect_leaf_proto",
    path = "leaf.proto",
)

proto_like(
    name = "aspect_mid_proto",
    path = "mid.proto",
)

go_proto_like(
    name = "aspect_leaf_go_proto",
    importpath = "example.com/leaf",
    proto = ":aspect_leaf_proto",
)

go_proto_like(
    name = "aspect_mid_go_proto",
    importpath = "example.com/mid",
    proto = ":aspect_mid_proto",
    deps = [":aspect_leaf_go_proto"],
    expected_imports = ["leaf.proto=example.com/leaf"],
)

genrule(
    name = "local_output_to_bindir_genrule",
    outs = ["local_output_to_bindir_genrule.txt"],
    cmd = "echo ok > $@",
    local = True,
    message = "Generating local output_to_bindir genrule",
    output_to_bindir = True,
)
