load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")
load("@io_bazel_rules_go//proto:compiler.bzl", "go_proto_compiler")
load("@io_bazel_rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")

package(default_visibility = ["//visibility:public"])

go_library(
    name = "hello_lib",
    srcs = ["lib.go"],
    importpath = "example.com/hello/lib",
)

go_library(
    name = "combined_core",
    srcs = ["combined_core.go"],
    importpath = "example.com/hello/combined",
)

go_library(
    name = "combined",
    srcs = ["combined_extra.go"],
    embed = [":combined_core"],
    importpath = "example.com/hello/combined",
)

go_binary(
    name = "hello",
    srcs = ["main.go"],
    deps = [":hello_lib"],
)

go_binary(
    name = "root_alias_hello",
    srcs = ["main.go"],
    deps = ["@hello_go_root//:hello_lib"],
)

proto_library(
    name = "message_proto",
    srcs = ["message.proto"],
)

go_proto_library(
    name = "message_go_proto",
    proto = ":message_proto",
)

go_proto_compiler(
    name = "message_compiler",
    plugin = ":hello",
)
