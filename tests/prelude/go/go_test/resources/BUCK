load("//tests/prelude:py_assertion.bzl", "py_assertion")

oncall("golang")

prelude = native

prelude.go_test(
    name = "test",
    srcs = ["resources_test.go"],
    resources = ["testdata/input"],
)

py_assertion(
    name = "check_output",
    script = """
import subprocess
import sys
assert "PASS" in subprocess.check_output([sys.argv[1]]).decode()
""",
    script_args = ["$(location_exec :test)"],
)
