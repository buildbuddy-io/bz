load("@prelude//utils:source_listing.bzl", "source_listing")

oncall("golang")

source_listing()

prelude = native
go_library = prelude.go_library
go_unittest = prelude.go_test

go_library(
    name = "gobuckifylib",
    srcs = glob(
        ["*.go"],
        exclude = ["*_test.go"],
    ),
    visibility = ["PUBLIC"],
)

go_unittest(
    name = "gobuckifylib_test",
    srcs = glob(["*_test.go"]),
    target_under_test = ":gobuckifylib",
)
