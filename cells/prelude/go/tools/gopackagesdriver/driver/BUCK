load("@prelude//utils:source_listing.bzl", "source_listing")

oncall("golang")

source_listing()

prelude = native

prelude.go_library(
    name = "driver",
    srcs = glob(
        ["*.go"],
        exclude = ["*_test.go"],
    ),
    visibility = ["PUBLIC"],
    deps = [
        "prelude//go/tools/gopackagesdriver/third-party:golang.org/x/tools/go/packages",
    ],
)

prelude.go_test(
    name = "driver_test",
    srcs = glob(["*_test.go"]),
    target_under_test = ":driver",
    visibility = ["PUBLIC"],
)
