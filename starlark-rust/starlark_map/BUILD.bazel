load("@crates//:defs.bzl", "aliases", "all_crate_deps")
load("@rules_rust//cargo:defs.bzl", "cargo_build_script")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_proc_macro")

package(default_visibility = ["//visibility:public"])

COMMON_RUSTC_ENV = {
    "CARGO_MANIFEST_DIR": "starlark-rust/starlark_map",
    "CARGO_PKG_AUTHORS": "Facebook",
    "CARGO_PKG_DESCRIPTION": "Map implementation with starlark-rust specific optimizations",
    "CARGO_PKG_HOMEPAGE": "",
    "CARGO_PKG_LICENSE": "Apache-2.0",
    "CARGO_PKG_LICENSE_FILE": "",
    "CARGO_PKG_NAME": "starlark_map",
    "CARGO_PKG_README": "",
    "CARGO_PKG_REPOSITORY": "https://github.com/facebook/starlark-rust",
    "CARGO_PKG_VERSION": "0.13.0",
    "CARGO_PKG_VERSION_MAJOR": "0",
    "CARGO_PKG_VERSION_MINOR": "13",
    "CARGO_PKG_VERSION_PATCH": "0",
    "CARGO_PKG_VERSION_PRE": "",
    }

cargo_build_script(
    name = "build_script",
    crate_name = "starlark_map_build_script",
    crate_root = "build.rs",
    srcs = ["build.rs"],
    edition = "2024",
    aliases = aliases(build = True, build_proc_macro = True),
    deps = all_crate_deps(build = True) + [],
    proc_macro_deps = all_crate_deps(build_proc_macro = True) + [],
    rustc_env = COMMON_RUSTC_ENV,
    data = glob(["**/*.proto", "**/*.lalrpop"], allow_empty = True),
)

rust_library(
    name = "starlark_map",
    crate_name = "starlark_map",
    crate_root = "src/lib.rs",
    srcs = glob(["src/**/*.rs"]),
    edition = "2024",
    crate_features = [
        "default",
        "pagable_dep",
    ],
    aliases = aliases(),
    deps = all_crate_deps(normal = True) + [
        ":build_script",
        "//allocative/allocative:allocative",
        "//gazebo/dupe:dupe",
        "//gazebo/strong_hash:strong_hash",
        "//pagable:pagable",
    ],
    proc_macro_deps = all_crate_deps(proc_macro = True) + [
        "//pagable_derive:pagable_derive",
    ],
    rustc_env = COMMON_RUSTC_ENV,
    compile_data = glob([
        "**/*",
    ], allow_empty = True, exclude = [
        "BUILD.bazel",
        "BUCK",
        "Cargo.toml",
        "fuzz/**",
    ]),
)
